{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Course Minimal course data",
  "description": "Structured information and schedule data for one course edition.",
  "type": "object",
  "additionalProperties": false,
  "required": ["information", "instructor", "schedule"],
  "properties": {
    "updates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text"],
        "properties": {
          "text": {"type": "string", "minLength": 1}
        }
      }
    },
    "information": {"$ref": "#/$defs/information"},
    "instructor": {"$ref": "#/$defs/person"},
    "staff": {
      "description": "Optional staff member. Omit or use null when unassigned.",
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/staff"}
      ]
    },
    "schedule": {"$ref": "#/$defs/schedule"}
  },
  "$defs": {
    "information": {
      "type": "object",
      "additionalProperties": false,
      "required": ["meeting", "location"],
      "properties": {
        "meeting": {
          "type": "object",
          "additionalProperties": false,
          "required": ["days", "time"],
          "properties": {
            "days": {"type": "string", "minLength": 1},
            "time": {"type": "string", "minLength": 1}
          }
        },
        "location": {"type": "string", "minLength": 1},
        "platforms": {
          "type": "array",
          "items": {"$ref": "#/$defs/link"}
        }
      }
    },
    "person": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "url", "photo"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri-reference"},
        "photo": {"type": "string", "format": "uri-reference"},
        "office_hours": {"$ref": "#/$defs/officeHours"}
      }
    },
    "staff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role", "photo"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "role": {"type": "string", "minLength": 1},
        "photo": {"type": "string", "format": "uri-reference"},
        "office_hours": {"$ref": "#/$defs/officeHours"}
      }
    },
    "officeHours": {
      "type": "object",
      "additionalProperties": false,
      "required": ["day", "time"],
      "properties": {
        "day": {"type": "string", "minLength": 1},
        "time": {"type": "string", "minLength": 1},
        "location": {"type": "string", "minLength": 1}
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sections"],
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/section"}
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "lectures"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "lectures": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/lecture"}
        }
      }
    },
    "lecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "date", "title"],
      "properties": {
        "number": {"type": "integer", "minimum": 1},
        "date": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "notes": {
          "type": "array",
          "items": {"$ref": "#/$defs/note"}
        },
        "slides": {
          "type": "array",
          "items": {"$ref": "#/$defs/slide"}
        },
        "reference": {
          "type": "array",
          "items": {"$ref": "#/$defs/link"}
        },
        "assignment": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "note_text": {"type": "string"}
      }
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": {"type": "string", "format": "uri-reference"}
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri-reference"}
      }
    },
    "slide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file"],
      "properties": {
        "file": {"type": "string", "pattern": "\\.pdf$"},
        "cover": {"type": "string", "pattern": "\\.(png|jpe?g|webp)$"}
      }
    }
  }
}
